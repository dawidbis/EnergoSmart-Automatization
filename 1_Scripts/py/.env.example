# Email Configuration (dla simulate_clients.py)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password
RECIPIENT_EMAIL=your-test-inbox@gmail.com

# IMAP cleanup (clean_test_documents.py --target emails)
# Server/port are auto-detected from your email domain; uncomment to override.
# Login reuses RECIPIENT_EMAIL + SENDER_PASSWORD (set IMAP_PASSWORD only if the
# monitored inbox uses a different password than the sender).
# IMAP_SERVER=imap.gmail.com
# IMAP_PORT=993
# IMAP_PASSWORD=

# Database Configuration
DB_PATH=../../2_Database/energosmart_history.db

# Data Generation
NUM_RECORDS=500000
NUM_CLIENTS=150
ANOMALY_THRESHOLD_PERCENT=30
